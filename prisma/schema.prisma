generator client {
  provider = "prisma-client-js"
}

datasource db {
  // DATABASE_URL > Transaction pooler (port 6543) -- runtime queries via PgBouncer
  // DIRECT_URL   > Session pooler   (port 5432) -- prisma db push / migrate
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ItemStatus {
  AVAILABLE
  BORROWED
}

model Item {
  id              String      @id @default(uuid())
  name            String
  category        String
  status          ItemStatus  @default(AVAILABLE)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt      @map("updated_at")
  borrowLogs      BorrowLog[]

  @@map("items")
}

model BorrowLog {
  id              String    @id @default(uuid())
  itemId          String    @map("item_id")
  item            Item      @relation(fields: [itemId], references: [id])
  borrowerName    String    @map("borrower_name")
  department      String
  borrowedAt      DateTime  @default(now()) @map("borrowed_at")
  expectedReturn  DateTime  @map("expected_return")
  returnedAt      DateTime? @map("returned_at")
  returnedByStaff Boolean   @default(false) @map("returned_by_staff")

  @@map("borrow_logs")
}
